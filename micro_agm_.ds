		form Book_a_Meeting_Room
		{
			displayname = "Book a Meeting Room"
			success message = "Booked Successfully! Confirmation mail has been sent to you."
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Name
			(
    			type = name
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Staff_ID
			(
    			type = text
				displayname = "Staff ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Official_Email
			(
    			type = email
				displayname = "Official Email"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Department
			(
				type = picklist
				values = {"Department 1","Department 2","Department 3"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Choose_a_room
			(
				type = radiobuttons
				displayname = "Choose a Room"
				values = {"Conference Room 1","Conference Room 2","Conference Room 3"}
	 			row = 1
	 			column = 1   
				width = 300px
			)
			must have From
			(
    			type = datetime
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have To
			(
    			type = datetime
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Brief_Description_of_Conference
			(
    			type = textarea
				displayname = "Brief Description of Conference"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Book Now"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
