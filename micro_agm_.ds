	reports
	{
		default list Apresenta_o_Micro_AGM_Report
		{
			displayName = "Apresentação Micro AGM Relatório"
			show all rows from Apresenta_o_Micro_AGM    
			(
				rea as "Contratos ativos por área "
			)
		}
		default list Contratos_a_vencer_Report
		{
			displayName = "Contratos a vencer Relatório"
			show all rows from Contratos_a_vencer    
			(
				Contratos_a_vencer as "Contratos a vencer "
			)
		}
		calendar Meeting_Schedules
		{
			displayName = "Meeting Schedules"
			show all rows from Book_a_Meeting_Room    
			(
				Name 
				From
				To
				Brief_Description_of_Conference as "Brief Description of Conference"
				Department
				Official_Email as "Official Email"
				Staff_ID as "Staff ID"
				Choose_a_room as "Choose a Room"
			)
			filters
			(
				Choose_a_room
			)
			options
			(
				display type = week
				display field = Name
				start date = From
				end date = To
			)
		}
		default list micro_agm_Report
		{
			displayName = "micro agm Relatório"
			show all rows from micro_agm    
		}
		default list gest_o_de_contratos_Report
		{
			displayName = "gestão de contratos Relatório"
			show all rows from gest_o_de_contratos    
			(
				Contratos_ativos_por_rea as "Área"
				Quantidade_de_contratos as "Quantidade de contratos "
			)
		}
		default list Contratos_a_vencer1_Report
		{
			displayName = "Contratos a vencer Relatório"
			show all rows from Contratos_a_vencer1    
			(
				Contratos_a_vencer as "Contratos a vencer "
				Data_do_vencimento as "Data do vencimento "
			)
		}
		default list Saving_da_negocia_o_Report
		{
			displayName = "Saving da negociação Relatório"
			show all rows from Saving_da_negocia_o    
			(
				Contrato as "Contrato "
				Or_ado as "Orçado "
				Realizado as "Realizado "
				Saving_do_contrato as "Saving do contrato "
