		workflow
		{
		form
		{
			Run_Scripts_On_Always as "Run Scripts - On Always"
			{
				type =  form
				form = Book_a_Meeting_Room

				record event = on add or edit

				on user input of From
				{
					actions 
					{
						custom deluge script
						(
											//validating 'From' and 'To' time values
										if(input.From <= zoho.currenttime)
										{
											alert "Please enter a valid future date!";
										}
										else if(input.From > input.To)
										{
											alert "Plaese enter valid 'From' time according to 'To' time!";
										}
						)
					}
				}

			}
			Run_Scripts_On_Always1 as "Run Scripts - On Always"
			{
				type =  form
				form = Book_a_Meeting_Room

				record event = on add or edit

				on user input of To
				{
					actions 
					{
						custom deluge script
						(
											//validating 'From' and 'To' time values
										if(input.To <= zoho.currenttime)
										{
											alert "Please enter a valid future date!";
										}
										else if(input.From > input.To)
										{
											alert "Plaese enter valid 'To' time according to 'From' time !";
										}
						)
					}
				}

			}
			Run_Scripts_While_Adding_ as "Run Scripts - While Adding a Record"
			{
				type =  form
				form = Book_a_Meeting_Room

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											//Booking confirmation notification to user
										sendmail
										[
											from :zoho.adminuserid
											to :input.Official_Email
											subject :"Conference Room Booking - Confirmation"
											message :"Hi " + input.Name + ",<div>&nbsp;&nbsp;</div><div>&nbsp;Your booking has been successfully completed.&nbsp;</div><div><br></div><div>&nbsp;Please find the booking details here,</div><div>&nbsp;</div><div>&nbsp;Booked Room :" + input.Choose_a_room + "</div><div><br></div><div>&nbsp;From&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :" + input.From + "</div><div><br></div><div>&nbsp;To&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :" + input.To + "</div><div><br></div><div><br></div><div><br></div><div>Thanks and Regards,</div><div>" + zoho.adminuser + "</div>"
										]
						)
					}
				}

			}
			Run_Scripts_While_Adding_1 as "Run Scripts - While Adding a Record"
			{
				type =  form
				form = Book_a_Meeting_Room

				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											//validating 'From' and 'To' time values
										if(input.From <= zoho.currenttime || input.To <= zoho.currenttime)
										{
											alert "Please enter a valid future date for booking!";
											cancel submit;
										}
										if(input.From > input.To)
										{
											alert "Plaese enter valid 'From' and 'To' time!";
											cancel submit;
										}
						)
					}
				}

			}
		}






	}
