<script>
window.ppFiltrarProjetos = function() {
    var painel = document.getElementById("ppDashboard");
    var campo = document.getElementById("ppBusca");

    if (!painel || !campo) {
        return;
    }

    var termo = campo.value.toLowerCase().trim();
    var cards = painel.querySelectorAll(".pp-card");
    var contagens = {
        pendente: 0,
        andamento: 0,
        finalizada: 0
    };

    var totalVisivel = 0;

    for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var status = card.getAttribute("data-status");
        var encontrado = card.textContent.toLowerCase().indexOf(termo) !== -1;

        card.style.display = encontrado ? "" : "none";

        if (encontrado) {
            totalVisivel++;
            contagens[status]++;
        }
    }

    var badges = painel.querySelectorAll("[data-count]");

    for (var j = 0; j < badges.length; j++) {
        var badge = badges[j];
        var chave = badge.getAttribute("data-count");

        badge.textContent = contagens[chave];
    }

    var resultado = document.getElementById("ppResultado");

    if (resultado) {
        resultado.textContent = termo === ""
            ? "Exibindo todas as iniciativas"
            : "Exibindo " + totalVisivel + "resultado(s)";
    }
};

(function() {
    var update = document.getElementById("ppUpdate");

    if (update) {
        update.textContent = "Atualizado em " + new Date().toLocaleDateString("pt-BR");
    }
})();
</script>
