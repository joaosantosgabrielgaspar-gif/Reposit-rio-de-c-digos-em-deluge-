<%{
	registros = Projetos_e_Processos[ID != null];
	demandasPendentes = List();
	demandasAndamento = List();
	demandasFinalizadas = List();
	for each  registro in registros
	{
		valorPendente = ifnull(registro.Demandas_Pendentes_teste,"").toString();
		valorAndamento = ifnull(registro.Demandas_em_andamento,"").toString();
		valorFinalizado = ifnull(registro.Demandas_finalizadas,"").toString();
		if(valorPendente.trim() != "")
		{
			demandasPendentes.add(valorPendente.trim());
		}
		if(valorAndamento.trim() != "")
		{
			demandasAndamento.add(valorAndamento.trim());
		}
		if(valorFinalizado.trim() != "")
		{
			demandasFinalizadas.add(valorFinalizado.trim());
		}
	}
	totalDemandas = demandasPendentes.size() + demandasAndamento.size() + demandasFinalizadas.size();
	%>
