		workflow
		{
		form
		{
			Atualizar_Status_anexo as "Atualizar Status anexo"
			{
				type =  form
				form = Consumo2

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Arquivo_da_fatura != "")
										{
											input.Status_Anexo1 = "Tem anexo";
										}
										else
										{
											input.Status_Anexo1 = "Não tem anexo";
										}
						)
					}
				}

			}
			Esconder_Dt_clima as "Esconder Dt clima"
			{
				type =  form
				form = Usinas

				record event = on add or edit
					status = inactive

				on user input of Filial_climatizada
				{
					actions 
					{
						custom deluge script
						(
											if(input.Filial_climatizada != null && input.Filial_climatizada == "Não")
										{
											show Caso_a_filial_n_o_seja_climatizada_informe_aqui_a_data_que_ser_realizada_a_climatiza_o;
										}
										else
										{
											hide Caso_a_filial_n_o_seja_climatizada_informe_aqui_a_data_que_ser_realizada_a_climatiza_o;
										}
						)
					}
				}

			}
			esconder_Usinas as "esconder Usinas"
			{
				type =  form
				form = Usinas

				record event = on add or edit
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Caso_a_filial_n_o_seja_climatizada_informe_aqui_a_data_que_ser_realizada_a_climatiza_o;
						)
					}
				}

			}
			Formata_o_condicional as "Formatação condicional"
			{
				type =  form
				form = Gera_o_Usinas

				record event = on add

				field rules
				{
				}

			}
			Formata_o_condicional1 as "Formatação condicional"
			{
				type =  form
				form = Copy_of_Gera_o_Usinas

				record event = on add

				field rules
				{
				}

			}
		}






