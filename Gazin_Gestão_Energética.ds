	reports
	{
		default list Cad_stro_de_usinas_Report
		{
			displayName = "Cadástro de usinas Relatório"
			show all rows from Cad_stro_de_usinas    
			(
				Nome
				Filial
				CNPJ
				UF
				Investimento_total as "Investimento total "
				Pot_ncia_kWp as "Potência (kWh) instalada "
