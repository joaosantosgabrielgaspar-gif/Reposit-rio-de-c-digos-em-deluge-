				Meta_kwh_m_s as "Meta kwh mês "
				Inicio_de_opera_o as "Inicio de operação "
				Tipo as "Local de instalação "
				Tipo_de_GD as "Tipo de GD"
				Auto_produtora as "Auto produtora "
				UC
				Munic_pio as "Município "
				CC_usinas as "CC usinas "
				Documentos_do_projeto as "Documentos do projeto "
				Quantas_Fl_atende as "Quantas Fl atende"
			)
		}
