		functions
		{
			ocultar_colunas as "ocultar colunas"
			{
				type =  functions
				form = demandas
				execution type = for each record	
					status = inactive
				on start
				{
					actions  (status.contains("Concluída"))
					{
						sendmail
						(
							from : "zoho.loginuserid"
							to : "maiara.fernandes@gazin.com.br"
							subject : "Maiara, é um teste"
							message : "<section class=\"text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--header-height)\" dir=\"auto\" data-turn-id=\"6153396b-9cef-4874-bf47-a900582ef8d7\" data-testid=\"conversation-turn-1\" data-scroll-anchor=\"false\" data-turn=\"user\">O usuário concluiu uma demanda aberta. Acesse a aplicação para mais informações.<br></section><div><br></div>"
							content type : Plain Text
