				status_atual as "Status Atual"
				data_alteracao as "Data da Alteração"
				responsavel_alteracao as "Responsável da Alteração"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status_anterior == "Aguardando Retorno")
				fields = [status_anterior]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status_anterior == "Cancelada")
				fields = [status_anterior]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status_anterior == "Concluída")
				fields = [status_anterior]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting4"
				{
				condition = (status_anterior == "Em Andamento")
				fields = [status_anterior]
				format = "color:#ffffff;background-color:#3598db;"
				}
			)
		}
