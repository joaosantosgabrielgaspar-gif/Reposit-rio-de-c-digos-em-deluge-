		form comentarios
		{
			displayname = "Comentários"
			success message = "Dados adicionados com sucesso!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			demanda
			(
				type = picklist	
				displayname = "Demanda"
				values  = demandas.ID
    			displayformat = [numero_demanda]
				allow new entries
				[
					displayname = "Adicionar Novo"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			conteudo
			(
    			type = textarea
				displayname = "Conteúdo"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			data_comentario
			(
    			type = datetime
				displayname = "Data do Comentário"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			autor
			(
    			type = text
				displayname = "Autor"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Enviar"
					)
					reset
					(
   						type = reset
   						displayname = "Redefinir"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Atualizar"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancelar"
					)
				}
			}
		}
