				width = medium
			)
			prioridade
			(
				type = picklist
				displayname = "Prioridade"
				values = {"Crítica","Urgente","Alta","Média","Baixa"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			impacto_operacional
			(
				type = picklist
				displayname = "Impacto Operacional"
				maxchar = 100
				values = {"Muito alto","Alto","Médio","Baixo"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			data_solicitacao
			(
