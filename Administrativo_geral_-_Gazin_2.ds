 application "Administrativo geral - Gazin 2"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form Atividades_di_rias_Ariel
		{
			displayname = "Atividades diárias - Ariel"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Atividades_Di_ria
			(
    			type = text
				displayname = "Atividades - Diária "
	 			row = 1
	 			column = 1   
				width = medium
			)
			Atividades
			(
				type = picklist	
				displayname = "Atividades "
				values  = demandas.ID
    			displayformat = [tituloDaDemanda]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Finalizado","Em andamento","Pendente"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Data_estimada_para_a_conclus_o
			(
    			type = date
				displayname = "Data estimada para a conclusão "
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Rich_Text
			(
    			type = textarea
				displayname = "Comentários "
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Pontua_o_de_conclus_o
			(
    			type = text
				displayname = "Qualidade "
	 			row = 1
	 			column = 1   
				width = medium
			)
			Pontualidade
			(
    			type = text
				displayname = "Pontualidade "
	 			row = 1
	 			column = 1   
				width = medium
			)
			Arquivos
			(
    			type = upload file
				displayname = "Arquivos "
    			file count = 10
				browse = local_drive
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
