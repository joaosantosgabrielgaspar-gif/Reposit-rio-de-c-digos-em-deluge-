	reports
	{
		list Relat_rio_ADM_1
		{
			displayName = "Relatório ADM 1"
			show all rows from demandas  [status.contains("Concluída")]  
			(
				numero_demanda as "Número da Demanda"
				tituloDaDemanda as "Título"
