				descricao as "Descrição"
			)
		}
		list Copy_of_Relat_rio_ADM_1
		{
			displayName = "Copy of Relatório ADM 1"
			show all rows from demandas    
			(
				numero_demanda as "Número da Demanda"
				tituloDaDemanda as "Título"
				area_solicitante as "Área Responsável "
				Respons_vel_pela_demanda as "Responsável pela execução "
				tipo_demanda as "Área Solicitante"
				prioridade as "Prioridade"
				data_solicitacao as "Data de Solicitação"
				prazo_entrega as "Prazo de Entrega"
				Hor_rio_estimado_entrega as "Horário estimado - entrega "
				status as "Status"
				descricao as "Descrição"
			)
		}
		list Copy_of_Relat_rio_de_Demandas_ADM
		{
			displayName = "Copy of Relatório de Demandas ADM"
			show all rows from demandas    
			(
				numero_demanda as "Número da Demanda"
				tituloDaDemanda as "Título"
				descricao as "Descrição"
				area_solicitante as "Área Responsável "
				prioridade as "Prioridade"
				tipo_demanda as "Área Solicitante"
				data_solicitacao as "Data de Solicitação"
				prazo_entrega as "Prazo de Entrega"
				status as "Status"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (area_solicitante == "Contratos")
				fields = [area_solicitante]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (area_solicitante == "Contratos Imobiliários")
				fields = [area_solicitante]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (area_solicitante == "Dados")
				fields = [area_solicitante]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		list comentarios_Report
		{
			displayName = "Relatório de Comentários"
			show all rows from comentarios    
			(
				demanda as "Demanda"
				conteudo as "Conteúdo"
				data_comentario as "Data do Comentário"
				autor as "Autor"
			)
		}
		list demandas_Report
		{
			displayName = "Relatório de Demandas ADM"
			show all rows from demandas    
			(
				numero_demanda as "Número da Demanda"
				(
					width = 67px
				)
				tituloDaDemanda as "Título"
				(
					width = 288px
				)
				descricao as "Descrição"
				(
					width = 515px
				)
				area_solicitante as "Área Responsável "
				(
					width = 180px
				)
				prioridade as "Prioridade"
				(
					width = 111px
				)
				tipo_demanda as "Área Solicitante"
				(
					width = 176px
				)
				data_solicitacao as "Data de Solicitação"
				(
					width = 166px
				)
				prazo_entrega as "Prazo de Entrega"
				(
					width = 152px
				)
				status as "Status"
				(
					width = 116px
				)
				Hor_rio_estimado_entrega as "Horário estimado - entrega "
				(
					width = 67px
				)
				Respons_vel_pela_demanda as "Responsável pela execução "
				(
					width = 219px
				)
				Anexos_do_Detalhamento as "Anexos do Detalhamento "
				(
					width = 820px
				)
			)
			sort by
			(
				prioridade ascending
			)
			custom actions
			(
				"DEMANDAS OCULTAS"
				(
	  			workflow = DEMANDAS_OCULTAS
				show action in view header = true
				condition = (status.contains("Concluída") || status.contains("Cancelada"))
				confirmation before execution
				(
					message for individual record = "Executar a ação DEMANDAS OCULTAS para este registro?"
					confirm button text = "Sim"		
					cancel button text = "Não"
				)
				)
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (area_solicitante == "Contratos")
				fields = [area_solicitante]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (area_solicitante == "Contratos Imobiliários")
				fields = [area_solicitante]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (area_solicitante == "Dados")
				fields = [area_solicitante]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban demandas_by_area_solicitante
		{
			displayName = "Quadro"
			show all rows from demandas    
			(
				numero_demanda as "Número da Demanda"
				tituloDaDemanda as "Título"
				descricao as "Descrição"
				area_solicitante as "Área Responsável "
				prioridade as "Prioridade"
				tipo_demanda as "Área Solicitante"
				data_solicitacao as "Data de Solicitação"
				prazo_entrega as "Prazo de Entrega"
				status as "Status"
			)
			options
			(
	 			display field = area_solicitante
	 		)
			conditional formatting
			(
				"teste"
				{
				condition = (status == "Concluída")
				fields = [status]
				format = "background-color:#92d191;"
				}
				"New Formatting"
				{
				condition = (status == "Em Andamento")
				fields = [status]
				format = "background-color:#f2c47d;"
				}
				"pendente"
				{
				condition = (status.contains("Aberta"))
				fields = [status]
				format = ""
				}
			)
		}
		list historico_status_Report
		{
			displayName = "Todos os Históricos de Status"
			show all rows from historico_status    
			(
