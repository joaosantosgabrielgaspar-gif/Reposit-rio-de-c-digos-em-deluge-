   						type = submit
   						displayname = "Atualizar"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancelar"
					)
				}
			}
			blueprint components
			{
				stages = {"Demanda Criada","Demanda em Análise","Demanda Rejeitada","Demanda Aprovada","Demanda em Espera de Informações","Demanda em Execução","Demanda em Espera de Recursos","Demanda em Revisão","Demanda em Atraso","Demanda Suspensa","Demanda Finalizada com Sucesso","Demanda Rejeitada na Revisão","Demanda em Correção","Demanda Finalizada com Atraso","Demanda Encerrada"}
