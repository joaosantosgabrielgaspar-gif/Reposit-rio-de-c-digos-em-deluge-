<script>
window.gazinFiltrar = function() {
	var painel = document.getElementById("gazinDashboard");
	var campo = document.getElementById("gazinBusca");

	if (!painel || !campo) {
		return;
	}

	var termo = campo.value.toLowerCase().trim();
	var cards = painel.querySelectorAll(".gazin-card");
	var contagens = {
		pendente: 0,
		andamento: 0,
		finalizada: 0,
		desenvolvimento: 0,
		continuas: 0,
		prontos: 0
	};

	var totalVisivel = 0;

	for (var i = 0; i < cards.length; i++) {
		var card = cards[i];
		var encontrado = card.textContent.toLowerCase().indexOf(termo) !== -1;

		card.style.display = encontrado ? "" : "none";

		if (encontrado) {
			totalVisivel++;
			contagens[card.getAttribute("data-status")]++;
		}
	}

	var badges = painel.querySelectorAll("[data-count]");

	for (var j = 0; j < badges.length; j++) {
		badges[j].textContent = contagens[badges[j].getAttribute("data-count")];
	}

	var resultado = document.getElementById("gazinResultado");

	if (resultado) {
		resultado.textContent = termo === ""
			? "Exibindo todos os itens"
			: "Exibindo " + totalVisivel + "resultado(s)";
	}
};
</script>
