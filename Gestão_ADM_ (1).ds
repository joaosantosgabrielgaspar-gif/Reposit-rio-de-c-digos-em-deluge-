		form Submit_New_Complaint
		{
			displayname = "Submit New Complaint"
			success message = "Your complaint has been submitted successfully.!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Contact_Information
			(
    			type = plaintext
				value = "<font size=\"4\" color=\"#3394D8\"><b>Contact Information</b></font>"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Full_Name
			(
    			type = name
				displayname = "Full Name"
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Email
			(
    			type = email
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Phone_Number
			(
    			type = phonenumber
				displayname = "Phone Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Address
			(
    			type = address
     			capture_coordinates = true
     			adjust_using_map = false
     			address_line_1
     			(
	     			  type = address_line_1
	     			  displayname = "Address Line 1"
     			) 
     			address_line_2
     			(
	     			  type = address_line_2
	     			  displayname = "Address Line 2"
     			) 
     			district_city
     			(
	     			  type = district_city
	     			  displayname = "City / District"
     			) 
     			state_province
     			(
	     			  type = state_province
	     			  displayname = "State Province"
     			) 
     			postal_Code
     			(
	     			  type = postal_Code
	     			  displayname = "Postal Code"
     			) 
     			country
     			(
	     			  type = country
	     			  displayname = "Country"
     			) 
     			latitude
     			(
	     			  type = latitude
	     			  displayname = "latitude"
     			) 
     			longitude
     			(
	     			  type = longitude
	     			  displayname = "longitude"
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			We_re_sorry_Let_us_know_how_we_can_improve
			(
    			type = plaintext
				value = "<font size=\"4\" color=\"#3394D8\"><b>We're sorry. Let us know how we can improve.</b></font>"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Product_or_Type_of_Service
			(
				type = picklist
				displayname = "Product or Service"
				values = {"Product A or Service A","Product B or Service B","Product C or Service C"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Please_describe_your_complaint_in_details
			(
    			type = textarea
				displayname = "Please describe your complaint in details"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Image_If_applicable
			(
    			type = image
				displayname = "Image (If applicable)"
				source  = public_url,file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have How_can_we_fix_this_problem
			(
    			type = textarea
				displayname = "How can we fix this problem?"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
