		default list N_veis_Atacado4_Report
		{
			displayName = "Relatório LOG"
			show all rows from N_veis_Atacado4    
			(
				M_s as "Mês"
				N_vel as "Nível"
				Conta as "Conta "
				Respons_vel as "Responsável "
				Or_ado_R1 as "Orçado R$"
				Or_ado3 as "Orçado %"
				Realizado_R2 as "Realizado R$"
				Or_ado2 as "Diferença %"
				Diferen_a_R as "Diferença R$"
				A_o as "Ação "
				Inicio_a_o as "Inicio ação "
				Fim_a_o1 as "Fim ação "
				RESULTADO_ESPERADO as "RESULTADO  ESPERADO "
				RESULTADO_OBTIDO as "RESULTADO OBTIDO"
				Realizado as "Realizado %"
			)
			conditional formatting
			(
				"tarja azul"
				{
				condition = (M_s == "-")
				fields = [M_s, N_vel, Conta, Or_ado_R1, Or_ado3, Realizado_R2, Or_ado2, Diferen_a_R, A_o, Inicio_a_o, Fim_a_o1, RESULTADO_ESPERADO, RESULTADO_OBTIDO, Realizado]
				format = "color:#ffffff;background-color:#2f78d0;"
				}
				"New Formatting"
				{
				condition = (Respons_vel == "-")
				fields = [Respons_vel]
				format = "color:#2f78d0;background-color:#2f78d0;"
				}
			)
		}
